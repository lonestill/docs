{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Better Yandex Music",
  "colors": {
    "primary": "#16A34A",
    "light": "#07C983",
    "dark": "#15803D"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Документация",
        "groups": [
          {
            "group": "Начало работы",
            "pages": [
              "index",
              "quickstart"
            ],
            "icon": "rocket"
          },
          {
            "group": "Разработка плагинов",
            "icon": "puzzle-piece",
            "pages": [
              "plugin-structure",
              "plugin-settings"
            ]
          }
        ]
      },
      {
        "tab": "API",
        "groups": [
          {
            "group": "Модули",
            "icon": "code",
            "pages": [
              "api/player",
              "api/events",
              "api/storage",
              "api/ui",
              "api/http",
              "api/hotkeys",
              "api/clipboard",
              "api/patcher",
              "api/dom",
              "api/net",
              "api/react",
              "api/logger",
              "api/webpack"
            ]
          }
        ]
      },
      {
        "tab": "Примеры",
        "groups": [
          {
            "group": "Примеры плагинов",
            "icon": "book-open",
            "pages": [
              "examples/speed-control",
              "examples/hotkey-controls",
              "examples/now-playing-title",
              "examples/lastfm-scrobbler"
            ]
          }
        ]
      }
    ]
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "primary": {
      "type": "button",
      "label": "GitHub",
      "href": "https://github.com/lonestill/bym"
    }
  },
  "contextual": {
    "options": [
     "copy",
     "view",
     "chatgpt",
     "claude",
     "perplexity",
     "mcp",
     "cursor",
     "vscode"
   ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/lonestill/bym"
    }
  }
}
